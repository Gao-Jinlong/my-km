{
  "name": "my-km",
  "version": "1.0.0",
  "private": true,
  "description": "个人知识库系统 - Monorepo 项目",
  "scripts": {
    "dev": "pnpm dev:db && turbo run dev",
    "dev:db": "docker-compose up -d postgres",
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:all": "biome check --write . && oxlint",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/node": "^20.11.0",
    "oxlint": "^0.4.0",
    "prettier": "^3.2.4",
    "turbo": "^1.12.4",
    "typescript": "^5.7.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
