{
  "name": "my-km",
  "version": "1.0.0",
  "private": true,
  "description": "个人知识库系统 - Monorepo 项目",
  "scripts": {
    "dev": "pnpm dev:db && concurrently \"pnpm dev:mail\" \"pnpm dev:all\"",
    "dev:db": "docker-compose up -d postgres",
    "dev:mail": "maildev",
    "dev:all": "turbo run dev",
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "maildev": "maildev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:all": "biome check --write . && oxlint",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^22.11.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.7.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
