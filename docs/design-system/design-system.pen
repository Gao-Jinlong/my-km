      "y": 1048,
      "name": "Design System",
      "width": 2100,
      "fill": "$color.bg.primary",
      "layout": "vertical",
      "gap": 48,
      "padding": 48,
      "children": [
        {
          "type": "frame",
          "id": "F3Bmif",
          "name": "00 Overview",
          "width": "fill_container",
          "fill": "$color.bg.secondary",
          "stroke": "$color.border.default",
          "strokeWidth": 1,
          "layout": "vertical",
          "gap": 32,
          "padding": 40,
          "children": [
            {
              "type": "text",
              "id": "SDYRO",
              "name": "Heading",
              "fill": "$color.fg.primary",
              "content": "my-km Design System",
              "fontFamily": "Inter",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "IK9ku",
              "name": "Subtitle",
              "fill": "$color.fg.primary",
              "content": "AI-native Personal Knowledge Studio — Single visual source of truth",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "AAL9T",
              "name": "Philosophy",
              "fill": "$color.fg.primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Design-first: this .pen file is the authoritative visual spec. Code aligns to design, never the reverse.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "OCw5o",
              "name": "Architecture",
              "fill": "$color.fg.primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Three-tier tokens: Reference (Tier 1) -> System/Semantic (Tier 2) -> Component/Domain (Tier 3). Theme switching only remaps Tier 2/3.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "LxLyq",
              "name": "Stack",
              "fill": "$color.fg.primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Tech: design-tokens (Zod schema to CSS vars) -> design-system (React primitives + Tailwind preset) -> apps/web",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "s64AS6",
              "name": "Roadmap",
              "fill": "$color.fg.primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Stage 1 (current): foundations + tokens + governance docs. Stage 2: primitive components. Stage 3: business UI migration.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
