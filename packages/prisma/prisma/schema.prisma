// This is your Prisma schema file,
// learn more it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String? // OAuth users can have null passwords
  username String? @unique // Optional display name
  avatar   String?
  bio      String?

  // Account status
  isEmailVerified Boolean @default(false)
  isActive        Boolean @default(true)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  accounts           Account[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]

  @@index([email])
  @@index([username])
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  provider          String // 'github' | 'google'
  providerAccountId String
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  isActive     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Message {
  id             String   @id @default(cuid())
  threadId      String
  role           String // 'user' | 'assistant' | 'tool' | 'system'
  content        String?  @db.Text

  // Tool call 相关
  toolCalls      Json?    // [{ id, name }] - assistant 消息的工具调用摘要
  toolResultId   String?  // role === 'tool' 时关联的 tool call id

  // Token 统计
  tokenCount     Int?
  finishReason   String?  // 'stop' | 'tool_calls' | 'length' | 'error'

  // 元数据
  metadata       Json?    // 扩展字段：model used, latency, etc.

  createdAt      DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([createdAt])
  @@index([role])
}

model Thread {
  id        String   @id @default(cuid())
  userId    String?  // 关联用户
  title     String?  // 对话标题
  status    String   @default("active")  // active | archived | deleted

  // 模型配置（覆盖默认）
  model     String?
  provider  String?

  // 统计
  messageCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  runs     Run[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Run {
  id             String    @id @default(cuid())
  threadId       String
  status         String    @default("pending") // pending | running | interrupted | completed | failed | cancelled

  // 模型配置快照（Run 创建时的配置）
  model          String?
  provider       String?

  // Token 用量
  promptTokens     Int  @default(0)
  completionTokens Int  @default(0)
  totalTokens      Int  @default(0)

  // 时间
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([status])
  @@index([createdAt])
}

model RunEvent {
  id         Int      @id @default(autoincrement())
  runId      String
  threadId   String
  seq        Int      // 事件序号
  eventType  String   // 'messages' | 'lifecycle' | 'tools' | 'values' | 'error'
  eventName  String   // 'content-block-delta' | 'started' 等
  payload    Json     // 完整事件数据 @db.JsonB
  createdAt  DateTime @default(now())

  @@index([runId, seq])
  @@index([threadId, createdAt])
  @@index([runId])
}
