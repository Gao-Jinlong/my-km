# ============ Application ============
NODE_ENV=development              # development | production | test
PORT=3000                          # 后端服务器端口

# ============ Database ============
DATABASE_URL=postgresql://kmuser:kmpass@localhost:5432/km_db

# ============ Frontend ============
FRONTEND_URL=http://localhost:4000 # 前端 URL（用于生成邮件中的链接）
ALLOWED_ORIGINS=http://localhost:4000 # 允许的跨域来源（逗号分隔）

# ============ Logger ============
LOG_LEVEL=info                   # 日志级别: fatal | error | warn | info | debug | trace
LOG_FILE_PATH=./logs             # 日志文件路径
LOG_MAX_SIZE=20m                 # 单个日志文件最大大小
LOG_MAX_FILES=14d                # 保留日志文件数量（天）

# ============ LangGraph ============
CHECKPOINTER_BACKEND=memory         # memory (开发) | postgres (生产，需 DATABASE_URL)

# ============ AI Providers ============
ZHIPUAI_API_KEY=your_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
DASHSCOPE_API_KEY=your_dashscope_key_here

# 默认 AI 提供商 (zhipu | anthropic | openai | dashscope)
AI_PROVIDER=zhipu

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m              # Access Token 有效期（默认 15 分钟）
JWT_REFRESH_EXPIRATION=7d              # Refresh Token 有效期（默认 7 天）

# ============ Maildev (本地开发邮件服务) ============
MAILDEV_HOST=localhost
MAILDEV_PORT=1025                      # SMTP 端口
MAILDEV_WEB_PORT=1080                  # Web UI 端口
MAILDEV_FROM=noreply@my-km.com         # 发件人邮箱
MAILDEV_FROM_NAME=My-KM                # 发件人名称

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password        # 可选
REDIS_DB=0
CACHE_TTL=300                              # 缓存过期时间（秒），默认 5 分钟
CACHE_KEY_PREFIX=my-km:                    # 缓存键前缀
