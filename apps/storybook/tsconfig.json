{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "noEmit": true
    },
    "include": ["src/**/*", ".storybook/**/*"],
    "exclude": ["node_modules", "dist"]
}
